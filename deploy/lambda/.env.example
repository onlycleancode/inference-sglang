# Copy to .env on the Lambda VM and fill secrets. Never commit .env.

MINISGL_MODEL=Qwen/Qwen3-8B
MINISGL_SMOKE_MODEL=Qwen/Qwen3-0.6B
MINISGL_PORT=1919

# Required for deployed endpoints
MINISGL_API_KEY=
MINISGL_REQUIRE_API_KEY=1

# Hugging Face model download
HF_TOKEN=

# Cache directories (match compose volume mounts)
HF_HOME=/app/.cache/huggingface
TVM_FFI_CACHE_DIR=/app/.cache/tvm-ffi
FLASHINFER_WORKSPACE_BASE=/app/.cache/flashinfer

# Optional dtype override on 48 GB fallback GPUs
# MINISGL_DTYPE=auto
